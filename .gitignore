# ===========================================================================
# SehatSaathi-AI — .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Environment & secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/
*.whl

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
pytest.ini

# ---------------------------------------------------------------------------
# Type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# IDEs & editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Application runtime artifacts
# ---------------------------------------------------------------------------
logs/*.log
logs/*.log.*

# Data directories (only .gitkeep files should be committed)
data/uploads/*
data/processed/*
data/temp/*
!data/uploads/.gitkeep
!data/processed/.gitkeep
!data/temp/.gitkeep
!data/reference_ranges/.gitkeep

# FAISS indexes (Phase 4)
*.faiss
*.index*.chunks.pkl       # legacy pickle format — replaced by JSON
# SQLite dev database
*.db
*.sqlite
*.sqlite3

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.dockerignore

# ---------------------------------------------------------------------------
# Node.js / Frontend
# ---------------------------------------------------------------------------
node_modules/
frontend/node_modules/
frontend/dist/

# Streamlit cache
.streamlit/

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
desktop.ini
