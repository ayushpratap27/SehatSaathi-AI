# ===========================================================================
# SehatSaathi-AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file — it is in .gitignore.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=SehatSaathi-AI
APP_VERSION=0.1.0
ENV=development                       # development | staging | production
DEBUG=true

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# ---------------------------------------------------------------------------
# CORS  (comma-separated list of allowed origins)
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/app.log

# ---------------------------------------------------------------------------
# Database
# Development default: SQLite (no extra setup required)
# Production: Replace with a PostgreSQL URL
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./sehat_saathi.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sehat_saathi

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
TEMP_DIR=data/temp
MAX_UPLOAD_SIZE_MB=20                 # Phase 2: 20 MB limit

# ---------------------------------------------------------------------------
# Groq LLM  (Phase 5 — text generation)
# Get your free API key at: https://console.groq.com
# ---------------------------------------------------------------------------
GROQ_API_KEY=                         # Required — your Groq API key
GROQ_MODEL=llama-3.3-70b-versatile    # Recommended: llama-3.3-70b-versatile | llama3-8b-8192

# ---------------------------------------------------------------------------
# Embeddings  (Phase 6 — local, no API key needed)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ---------------------------------------------------------------------------
# Redis  (Phase 8)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=allenai-specter

# ---------------------------------------------------------------------------
# Security  (Phase 8)
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
